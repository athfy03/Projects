<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpeakUpApp.Views.PastQuizzesPage"
             NavigationPage.HasNavigationBar="False"
             Title="Past Quizzes">
    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0"
          BackgroundColor="#0077cc"
          Padding="10,40,10,10"
          ColumnSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                Text="←"
                Clicked="Back_Clicked"
                BackgroundColor="Transparent"
                TextColor="White"
                FontSize="32"
                WidthRequest="56"
                HeightRequest="56"
                Padding="0"
                HorizontalOptions="Start"
                VerticalOptions="Center" />

            <Label Grid.Column="1"
               Text="Past Quizzes"
               TextColor="White"
               FontSize="22"
               HorizontalOptions="Center"
               VerticalOptions="Center" />

            <Button Grid.Column="2"
                BackgroundColor="Transparent"
                IsEnabled="False"
                Opacity="0"
                WidthRequest="56"
                HeightRequest="56"
                Padding="0" />
        </Grid>


        <!-- List of sessions -->
        <CollectionView x:Name="SessionsList"
                Grid.Row="1"
                Margin="10"
                SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10"
                   Margin="0,5"
                   BorderColor="#0077cc"
                   CornerRadius="8">

                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="SessionCard_Tapped" />
                        </Frame.GestureRecognizers>

                        <StackLayout>
                            <Label Text="{Binding Date, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"
                           FontAttributes="Bold"/>
                            <Label Text="{Binding CorrectAnswers, StringFormat='Score: {0}'}" />
                        </StackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>



        <!-- Bottom nav -->
        <Grid Grid.Row="2"
            BackgroundColor="#0077cc">
            <Button Text="🏠"
                Clicked="HomeButton_Clicked"
                BackgroundColor="Transparent"
                TextColor="White"
                FontSize="26"
                HorizontalOptions="Center"
                VerticalOptions="Center" />
        </Grid>

    </Grid>
</ContentPage>
