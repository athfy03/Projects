<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpeakUpApp.Views.HomePage"
             Title="SpeakUp"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White">
    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- header -->
            <RowDefinition Height="*" />
            <!-- content -->
            <RowDefinition Height="60" />
            <!-- bottom nav -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackLayout Grid.Row="0"
                     BackgroundColor="#0077cc"
                     Padding="16,40,16,16">
            <Label Text="SpeakUp"
                   FontSize="26"
                   TextColor="White"
                   HorizontalOptions="Center" />
            <Label x:Name="LevelLabel"
                   Text="Level 1 • 0/100 XP"
                   FontSize="16"
                   TextColor="White"
                   HorizontalOptions="Center"/>

        </StackLayout>

        <!-- Main buttons -->
        <StackLayout Grid.Row="1"
                     VerticalOptions="Center"
                     HorizontalOptions="Center"
                     Spacing="20"
                     Padding="32,0">
            
            <Button Text="Start Quiz"
                    WidthRequest="280"
                    HeightRequest="64"
                    FontSize="18"
                    Clicked="StartQuiz_Clicked"
                    BackgroundColor="#0077cc"
                    TextColor="White"
                    CornerRadius="16" />

            <Button Text="Review Answers"
                    WidthRequest="280"
                    HeightRequest="64"
                    FontSize="18"
                    Clicked="ReviewAnswers_Clicked"
                    BackgroundColor="#0077cc"
                    TextColor="White"
                    CornerRadius="16" />

            <Button Text="Achievements"
                    WidthRequest="280"
                    HeightRequest="64"
                    FontSize="18"
                    Clicked="Achievements_Clicked"
                    BackgroundColor="#0077cc"
                    TextColor="White"
                    CornerRadius="16" />

            <Button Text="About Us"
                    WidthRequest="280"
                    HeightRequest="64"
                    FontSize="18"
                    Clicked="AboutUs_Clicked"
                    BackgroundColor="#0077cc"
                    TextColor="White"
                    CornerRadius="16" />
        </StackLayout>


        <!-- Bottom nav (icons can be replaced with images) -->
        <Grid Grid.Row="2"
            BackgroundColor="#0077cc">
            <Button Text="🏠"
                Clicked="HomeButton_Clicked"
                BackgroundColor="Transparent"
                TextColor="White"
                FontSize="26"
                HorizontalOptions="Center"
                VerticalOptions="Center" />
        </Grid>
    </Grid>
</ContentPage>
